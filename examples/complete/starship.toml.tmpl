# Starship prompt config — generated by crucible
# OS: {{ .os.name }}/{{ .os.arch }}, Host: {{ .os.hostname }}

[character]
success_symbol = "[➜](bold green)"
error_symbol = "[✗](bold red)"

{{ if lookPath "go" -}}
[golang]
symbol = "🐹 "
{{ end -}}

{{ if lookPath "node" -}}
[nodejs]
symbol = "⬢ "
{{ end -}}

[env_var.EDITOR]
variable = "EDITOR"
default = "{{ env "EDITOR" | default "vim" }}"
